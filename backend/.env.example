# SQLite (mặc định, chạy được ngay không cần cài Postgres)
DATABASE_URL="file:./dev.db"

# Nếu muốn dùng Postgres thay vì SQLite, đổi DATABASE_URL thành:
# DATABASE_URL="postgresql://tincay:tincay_dev_password@localhost:5432/tincay360?schema=public"
# và đổi `provider = "sqlite"` thành `provider = "postgresql"` trong prisma/schema.prisma

JWT_SECRET="change-me-in-production-please-use-long-random-string"
PORT=4000
HOST=0.0.0.0

# Dev: cho phép mọi origin hoặc chỉ localhost
# CORS_ORIGIN="http://localhost:5173"
# Production: chỉ cho phép domain chính thức
CORS_ORIGIN="https://cuahangphaohoa.shop"

# Seed admin user — đổi password trước khi deploy
ADMIN_EMAIL="admin@tincay360.vn"
ADMIN_PASSWORD="Admin@123"
ADMIN_NAME="Quản trị viên"
